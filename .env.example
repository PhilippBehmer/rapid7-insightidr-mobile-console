# Express backend listen port
PORT=3000

# Optional alternate path for persisted local session state
# Recommended local path: ./backend/local/config.json
IDR_CONFIG_FILE=./backend/local/config.json

# Optional secret used to encrypt remembered per-browser API keys
# If omitted, the backend creates a local secret file at ./backend/session-secret.hex
# IDR_SESSION_SECRET=replace-with-a-long-random-secret
