# Optional image override for docker-compose.yml
# Default: philippbehmer/rapid7-insightidr-mobile-console:latest
# POCKETSOC_IMAGE=philippbehmer/rapid7-insightidr-mobile-console:latest

# Optional host port for docker-compose.yml publishing
# POCKETSOC_HOST_PORT=3000

# Optional alternate path for persisted local session state
# POCKETSOC_CONFIG_FILE=./backend/local/config.json

# Optional secret used to encrypt remembered per-browser API keys
# If omitted, the backend creates a local secret file next to POCKETSOC_CONFIG_FILE.
# POCKETSOC_SESSION_SECRET_FILE=./backend/local/session-secret.hex
# POCKETSOC_SESSION_SECRET=replace-with-a-long-random-secret

# Optional attachment upload cap in bytes.
# Default: 50000000 (50 MB)
# POCKETSOC_ATTACHMENT_MAX_BYTES=50000000

# Optional: force the session cookie to include Secure even behind a TLS-terminating proxy.
# POCKETSOC_FORCE_SECURE_COOKIE=false
